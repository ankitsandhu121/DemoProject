{
  "name": "taskflow-sample",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace=taskflow-web",
    "start:api": "npm run start --workspace=taskflow-api",
    "test:acceptance": "playwright test --config=e2e/acceptance/playwright.config.ts",
    "test:acceptance:ui": "playwright test --config=e2e/acceptance/playwright.config.ts --ui",
    "test:regression": "playwright test --config=e2e/regression/playwright.config.ts"
  }
}
